# create-hermes-workspace — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   $EDITOR .env
#
# NEVER commit .env — only .env.example is tracked.
# See README.md for the full annotated table and where to get each key.

# ════════════════════════════════════════════════════════════════════════════
# 1. LLM PROVIDER KEYS  (set at least one — the agent picks the first that's
#    non-empty)
# ════════════════════════════════════════════════════════════════════════════

# Primary (recommended) — MiniMax
# Get your key at:  https://api.minimax.io/
MINIMAX_API_KEY=

# Fallback — OpenAI
# Get your key at:  https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Fallback — Anthropic
# Get your key at:  https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# ════════════════════════════════════════════════════════════════════════════
# 2. CONTAINER USER
#    Match the host user that owns this folder so files created inside the
#    container stay owned by you. Run `id` on the host to find yours.
# ════════════════════════════════════════════════════════════════════════════

HERMES_UID=1000
HERMES_GID=1000

# ════════════════════════════════════════════════════════════════════════════
# 3. GITHUB INTEGRATION
#    Used by `make worktree-push` to create repos and push via SSH.
# ════════════════════════════════════════════════════════════════════════════

GITHUB_USER=

# ════════════════════════════════════════════════════════════════════════════
# 4. APPLICATION
# ════════════════════════════════════════════════════════════════════════════

PORT=3000
APP_URL=http://localhost:3000
LOG_LEVEL=info

# ════════════════════════════════════════════════════════════════════════════
# 5. OPTIONAL — GATEWAY INTEGRATIONS
#    Uncomment the block for any chat platform you want the agent available on.
# ════════════════════════════════════════════════════════════════════════════

# --- Telegram ---
# Create a bot with @BotFather, get the token, then add the bot to a chat.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_CHATS=

# --- Discord ---
# Create an application + bot at https://discord.com/developers/applications.
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_CHANNELS=

# --- Slack ---
# Create a Slack app, install it to your workspace, copy the bot token.
# SLACK_BOT_TOKEN=
# SLACK_ALLOWED_CHANNELS=

# --- Matrix ---
# Create a bot account on your homeserver.
# MATRIX_ACCESS_TOKEN=
# MATRIX_HOMESERVER=
# MATRIX_ALLOWED_ROOMS=

# ════════════════════════════════════════════════════════════════════════════
# 6. OPTIONAL — OBSERVABILITY
# ════════════════════════════════════════════════════════════════════════════

# Sentry DSN for error reporting. Empty = disabled.
# SENTRY_DSN=

# ════════════════════════════════════════════════════════════════════════════
# 7. OPTIONAL — PUBLISHING (only relevant if you fork this and re-publish the
#    npm package)
# ════════════════════════════════════════════════════════════════════════════

# Generate at: https://www.npmjs.com/settings/<your-username>/tokens
# Use the "Automation" type with read+publish scope. DO NOT commit this.
# NPM_TOKEN=
